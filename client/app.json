{
  "expo": {
    "name": "GharsaAI",
    "slug": "agro",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/logo_gharsa.png",
    "scheme": "agro",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.khalil.agro"
    },
    "android": {
      "package": "com.khalil.agro",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo_gharsa.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_gharsa.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d631b",
          "dark": {
            "backgroundColor": "#0d631b"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableBackgroundColor": false,
            "extraParams": {
              "android.forceDarkAllowed": "false"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "854d7af5-95fb-403e-b59b-c0c4a5013914"
      }
    }
  }
}